# Merchant dashboard — Supabase connection (public anon key is safe; RLS-gated).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Sentry client-side crash reporting (optional). When unset, Sentry is a no-op
# and the app builds/boots normally. Set to your project's browser DSN to
# capture white-screen errors on the money surfaces.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (build-time only; optional). These are NOT shipped to
# the browser — they authorize the post-build "sentry:sourcemaps" step so Sentry
# can symbolicate (make readable) the minified stack traces from the static
# export. Leave unset and the build still succeeds — upload is simply skipped.
# Set all three (in CI or the owner's shell) to enable upload. Never commit real
# values; SENTRY_AUTH_TOKEN is a secret.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
