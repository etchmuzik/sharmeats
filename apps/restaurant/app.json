{
  "expo": {
    "name": "Sharm Eats Restaurant",
    "slug": "sharmeats-restaurant",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "sharmeatsrestaurant",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b0ee1d33-9c44-4d2a-9711-ec2d4f374eb0"
    },
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "eg.sharmeats.restaurant",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7a3cff"
      },
      "package": "eg.sharmeats.restaurant"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#7a3cff"
        }
      ],
      "expo-asset",
      "expo-notifications",
      [
        "@sentry/react-native",
        {
          "organization": "beyond-mngmt",
          "project": "sharmeats-restaurant",
          "url": "https://sentry.io/"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sharm Eats needs photo access so you can upload your verification documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b0ee1d33-9c44-4d2a-9711-ec2d4f374eb0"
      }
    },
    "owner": "etchmuzik"
  }
}
