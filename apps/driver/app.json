{
  "expo": {
    "name": "Sharm Eats Driver",
    "slug": "sharmeats-driver",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "sharmeatsdriver",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/85b2822a-7672-4a68-b7af-364773c5500c"
    },
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "eg.sharmeats.driver",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Sharm Eats uses your location to assign nearby deliveries and share your live position with customers while you deliver.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "During an active delivery, Sharm Eats uses your location in the background to keep the customer informed and dispatch accurate."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e7c91"
      },
      "package": "eg.sharmeats.driver",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0e7c91"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sharm Eats uses your location to assign nearby deliveries.",
          "locationAlwaysAndWhenInUsePermission": "During an active delivery, Sharm Eats shares your live location with the customer and dispatch even when the app is in the background.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-asset",
      "expo-notifications",
      [
        "@sentry/react-native",
        {
          "organization": "beyond-mngmt",
          "project": "sharmeats-driver",
          "url": "https://sentry.io/"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sharm Eats needs photo access so you can upload your verification documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "85b2822a-7672-4a68-b7af-364773c5500c"
      }
    },
    "owner": "etchmuzik"
  }
}
