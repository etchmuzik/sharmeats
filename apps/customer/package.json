    "expo-application": "~6.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.2",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-localization": "~16.0.1",
    "expo-location": "~18.0.10",
