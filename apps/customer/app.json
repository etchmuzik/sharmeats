{
  "expo": {
    "name": "Sharm Eats",
    "slug": "sharmeats-customer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sharmeats",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#100e12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "eg.sharmeats.customer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#100e12"
      },
      "package": "eg.sharmeats.customer"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d3628b78-b35a-4d15-a48a-c12b9579b682"
      }
    },
    "owner": "etchmuzik"
  }
}
