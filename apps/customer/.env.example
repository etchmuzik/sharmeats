# Sharmeats customer app — environment template
# Copy to `.env` and fill in your values. None are required for the mock layer.

# Flip to "true" to swap from in-memory mocks to the live Supabase backend.
# When true, the URL + ANON_KEY below MUST be set or the app will throw on first
# data call.
EXPO_PUBLIC_USE_SUPABASE=false

# Find these at: Supabase Dashboard → Project Settings → API
# https://app.supabase.com/project/<id>/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
