# Supabase CLI scratch
supabase/.temp/
# Build artifacts — signed binaries and deploy bundles must never be committed
# (a stray `git add -A` would otherwise commit a ~16MB signed .ipa). Build them
# locally / in CI and upload via Transporter/EAS/Play, don't track them.
*.ipa
*.aab
*.apk
*-deploy.zip
# Any build/export zip (e.g. landing/sharmeatslanding_*.zip) — never commit to
# this public repo. The narrower *-deploy.zip above missed timestamped exports.
*.zip
# Local design-tool scratch: multi-MB mockups + licensed stock photos, not source.
new style/
"new style/"

# Signing / store credentials — NEVER commit. ASC API keys (.p8), Google Play
# service-account JSONs, and anything under a per-app credentials/ dir are secrets.
# EAS reads them from disk at submit time; they live locally / in EAS, not in git.
**/credentials/
*.p8
*service-account*.json

.superpowers/
__pycache__/
*.pyc
