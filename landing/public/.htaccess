# Sharm Eats landing — Apache config for the Next.js static export on Hostinger.
#
# Next `output: export` + `trailingSlash: true` emits real per-route HTML
# (/index.html, /privacy/index.html), so we DON'T SPA-rewrite everything to one
# index. We just force HTTPS, serve clean URLs, set the AASA content-type
# (next.config headers() doesn't apply to a static export), and cache assets.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS.
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Serve existing files/dirs as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Clean URLs: /privacy → /privacy/index.html (trailingSlash export layout).
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]
</IfModule>

# Apple universal links: the AASA file has no extension and MUST be served as
# application/json, or iOS ignores it.
<IfModule mod_headers.c>
  <Files "apple-app-site-association">
    ForceType application/json
    Header set Content-Type "application/json"
  </Files>
</IfModule>

# Caching: hashed Next assets are immutable; HTML should revalidate.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Custom 404 (Next export writes 404.html).
ErrorDocument 404 /404.html
